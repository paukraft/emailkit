{
  "name": "sandbox",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run prisma:generate && next dev --turbopack --port 3210",
    "build": "bun run prisma:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "prisma:generate": "node -e \"require('node:fs').rmSync('generated/prisma', { recursive: true, force: true })\" && prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "typecheck": "bun run prisma:generate && tsc --noEmit",
    "check-types": "bun run prisma:generate && tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@lexical/code": "^0.42.0",
    "@lexical/html": "^0.42.0",
    "@lexical/link": "^0.42.0",
    "@lexical/list": "^0.42.0",
    "@lexical/react": "^0.42.0",
    "@lexical/rich-text": "^0.42.0",
    "@lexical/selection": "^0.42.0",
    "@lexical/utils": "^0.42.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "emailkit": "*",
    "humanize-duration": "^3.33.0",
    "lexical": "^0.42.0",
    "lucide-react": "^1.16.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/humanize-duration": "^3.27.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
