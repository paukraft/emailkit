{
  "name": "emailkit",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "postcss": "^8.5.8",
    "prettier": "^3.6.2",
    "sandbox": "workspace:*",
    "shadcn": "^4.1.2",
    "tailwindcss": "4",
    "turbo": "^2.6.0",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@remixicon/react": "^4.9.0",
    "class-variance-authority": "^0.7.1",
